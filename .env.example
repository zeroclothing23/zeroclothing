# ----------------------------------------------------------------------------
# ZERØ Clothing — Environment variables
# Copy to .env (and .env.local for Next dev) and fill in real values.
# ----------------------------------------------------------------------------

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_NUMBER="94742357709"   # SL international format, no +

# --- Database (Neon) ---
# Pooled connection (used by the app at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true"
# Direct connection (used by Prisma Migrate)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- NextAuth (Auth.js v5) ---
# Generate: openssl rand -base64 32
AUTH_SECRET="change-me-please"
AUTH_TRUST_HOST="true"
# Google OAuth (https://console.cloud.google.com → Credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Cloudinary (image storage) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Unsigned upload preset for client uploads (custom design page)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="zero_uploads"

# --- Resend (email) ---
RESEND_API_KEY=""
EMAIL_FROM="ZERØ Clothing <noreply@zeroclothing.lk>"
ADMIN_EMAIL="admin@zeroclothing.lk"

# --- PayHere (payments) ---
# Sandbox: https://sandbox.payhere.lk  | Live: https://www.payhere.lk
PAYHERE_MODE="sandbox"                 # "sandbox" | "live"
PAYHERE_MERCHANT_ID=""
PAYHERE_MERCHANT_SECRET=""             # from PayHere dashboard → Domains & Credentials

# --- Admin seed (used by prisma/seed.ts) ---
SEED_ADMIN_EMAIL="admin@zeroclothing.lk"
SEED_ADMIN_PASSWORD="ChangeMe123!"
